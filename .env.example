# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# Recurring price ID (Stripe Dashboard → Products) for the Premium plan
# (~1500-2000 KZT/month). Required for /pricing upgrade checkout; if unset,
# the checkout route returns "Premium plan not configured yet".
STRIPE_PREMIUM_PRICE_ID=
# Secret from the Stripe webhook endpoint config. When set, the webhook
# verifies signatures; subscription events upsert public.subscriptions.
STRIPE_WEBHOOK_SECRET=

# Email notifications (Resend) — optional in dev: when RESEND_API_KEY is
# missing, substitution emails are logged to the console instead of sent.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
